# MajNet node bootstrap config — copy to /etc/majnet/node.env on the target
# node and fill in. bootstrap.sh sources this file.

# Identity ---------------------------------------------------------------
NODE_NAME=prod                 # main | prod | private
NODE_ROLE=prod                 # main | prod | private (= trust zone)

# WireGuard mesh ---------------------------------------------------------
# Subnet 10.88.0.0/24 — main=.1, prod=.2, private=.3
WG_ADDRESS=10.88.0.2/24
WG_LISTEN_PORT=51820
# Private key is generated on first run into /etc/wireguard/wg0.key if unset.

# Peers: NAME:WG_IP:PUBKEY:ENDPOINT (endpoint = public IP:port; empty pubkey
# on first run — fill in after all nodes have printed their pubkeys).
WG_PEERS="
main:10.88.0.1:REPLACE_PUBKEY:203.0.113.1:51820
private:10.88.0.3:REPLACE_PUBKEY:203.0.113.3:51820
"

# Docker API (only bound on the WG interface, mTLS) ----------------------
DOCKER_API_PORT=2376
# Server cert/key + CA, issued by bootstrap/pki/gen-certs.sh; copy to:
#   /etc/majnet/pki/ca.pem  server-cert.pem  server-key.pem

# SSH --------------------------------------------------------------------
# Public keys allowed for the admin user (newline-separated).
ADMIN_USER=majnet
ADMIN_SSH_KEYS="
ssh-ed25519 AAAA... ondrej
"

# Main node only ----------------------------------------------------------
# Set by install.sh when MAJNET_DOMAIN is given: Caddy terminates TLS for
# webhooks + wizard, and the firewall admits 80/443 instead of 8080/7600
# (ADR 0006).
#MAIN_TLS_PROXY=1

# Agents -----------------------------------------------------------------
BESZEL_HUB_URL=http://10.88.0.1:8090     # Beszel hub on main node (over WG)
BESZEL_AGENT_KEY=                        # from the hub UI; empty = skip agent
RESTIC_REPOSITORY=                       # e.g. b2:majnet-backups (phase 5)
