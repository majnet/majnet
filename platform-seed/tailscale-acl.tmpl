  "acls": [
    // Admins reach the control plane: dashboard, Dozzle, Beszel (main node).
    { "action": "accept", "src": ["group:admins"], "dst": ["tag:main:*"] },

    // Project members reach only their own project's ingress.
    // {{range .Projects}}
    // { "action": "accept", "src": ["group:proj-{{.Name}}"], "dst": ["tag:proj-{{.Name}}:443"] },
